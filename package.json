{
  "name": "gitpulse",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:vite": "vite --host 127.0.0.1 --port 1420",
    "build": "tauri build",
    "build:vite": "tsc && vite build",
    "check": "npm run format:check && npm run lint && npm run build:vite && cargo gp-check && npm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:frontend && npm run lint:rust",
    "lint:frontend": "eslint .",
    "lint:rust": "cargo gp-lint",
    "test": "npm run test:all",
    "test:all": "npm run test:frontend && npm run test:rust",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test -c playwright.smoke.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "capture:readme": "playwright test -c playwright.screenshots.config.ts",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "test:rust": "cargo gp-test",
    "test:rust:filter": "cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "i18next": "^26.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.3"
  }
}
