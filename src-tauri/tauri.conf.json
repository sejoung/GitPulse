{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitPulse",
  "version": "0.1.0",
  "identifier": "com.gitpulse.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitPulse",
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  }
}
