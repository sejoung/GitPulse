{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node"],
    "strict": true
  },
  "include": [
    "tailwind.config.ts",
    "vite.config.ts",
    "playwright.config.ts",
    "playwright.smoke.config.ts",
    "playwright.screenshots.config.ts"
  ]
}
